def group_anagrams(strs: list[str]) -> list[list[str]]:
    groups = {}
    for s in strs:
        key = ''.join(sorted(s))
        if key not in groups:
            groups[key] = []
        groups[key].append(s)
    return list(groups.values())
def longest_consecutive(nums: list[int]) -> int:
    num_set = set(nums)
    res = 0
    for num in num_set:
        if num - 1 in num_set:
            continue
        length = 1
        while num + length in num_set:
            length += 1
        res = max(res, length)
    return res
def is_anagram(s: str, t: str) -> bool:
    if len(s) != len(t):
        return False
    count={}
    for c in s:
        count[c] = count.get(c,0) + 1
    for c in t:
        if c not in count:
            return False
        count[c] -= 1
        if count[c] < 0:
            return False
    return True


