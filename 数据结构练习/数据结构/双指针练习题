def delete(nums):
    slow = 0
    for fast in range(len(nums)):
        if nums[fast] != nums[slow]:
            slow += 1
            nums[slow] = nums[fast]
    return slow + 1
def drain(height):
    left,right = 0,len(height)-1
    s = 0
    while left < right:
        area = min(height[left], height[right]) * (right - left)
        s = max(s, area)
        if height[left] < height[right]:
            left += 1
        elif height[left] > height[right]:
            right -= 1
        else:
            left += 1
            right -= 1
    return s
height = [1,8,6,2,5,4,8,3,7]
print(drain(height))
